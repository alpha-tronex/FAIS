# Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/fais

# JWT
# Dev-only secret. Replace for production.
JWT_SECRET=dev-secret-change-me

# Server
PORT=3001

# SSN encryption (AES-256-GCM)
# Must be a base64-encoded 32-byte key.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SSN_ENCRYPTION_KEY_B64=xTQlJpH3vQNmiwENkZBYiWkXTAvR72aPD/1XPdoq1w=

# Email (invite + password reset). If unset, emails are logged but not sent.
# Option A: single URL
# SMTP_URL=smtps://USER:PASSWORD@smtp.example.com:465
# Option B: separate vars (e.g. Yahoo: smtp.mail.yahoo.com, port 465 or 587)
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=465
# SMTP_USER=your-email@yahoo.com
# SMTP_PASS=your-app-password
# SMTP_FROM=FAIS <your-email@yahoo.com>

# AI reports (optional). If unset, report endpoints return 503.
# OPENAI_API_KEY=sk-...

# Documents / AI Document analysis (Backblaze B2). If unset, document upload returns 503.
# In Backblaze B2: Bucket → Application Keys. Create a key; use keyID and applicationKey below.
# B2_KEY_ID = short Key ID only (e.g. 005a1b2c3d4e5f6789012345) — NOT the long application key
# B2_APP_KEY = the long applicationKey (secret) from the same key
# B2_BUCKET_NAME=your_bucket_name
# B2_ENDPOINT=s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004

# Document intake (optional). DOCUMENT_INTAKE_ENABLED=true enables analyze/list/apply routes.
# DOCUMENT_INTAKE_ON_UPLOAD=true runs intake after each PDF upload.
# DOCUMENT_INTAKE_TEXTRACT=true runs Amazon Textract (sync) when pdf-parse text is weak.
# Textract uses real AWS credentials — not B2 keys. Example: AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY.
# Sync API supports PDFs up to 3 pages; larger PDFs skip Textract (rawPayload.ocrTextractSkippedReason).

# Legacy SQL Server (for export -> JSON)
# Example (SQL auth):
# LEGACY_SQLSERVER_CONNECTION_STRING="Server=tcp:HOST,1433;Database=financialAff;User Id=USERNAME;Password=PASSWORD;Encrypt=true;TrustServerCertificate=true;"
LEGACY_SQLSERVER_CONNECTION_STRING=
